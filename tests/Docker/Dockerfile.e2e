# Test runner environment for Docker-based integration tests.
#
# Provides the .NET SDK and Node.js runtime. The Docker daemon is accessed via the
# host socket mounted at runtime (-v /var/run/docker.sock:/var/run/docker.sock).
#
# Usage (from repo root):
#   docker build -f tests/Docker/Dockerfile.e2e -t aspirec4-e2e-docker .
#   docker run --rm \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     -v $(pwd):/workspace \
#     -w /workspace \
#     aspirec4-e2e-docker \
#     dotnet test src/tests/AspireC4.IntegrationTests

FROM mcr.microsoft.com/dotnet/sdk:10.0

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        docker.io \
        ca-certificates \
        curl && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /workspace
WORKDIR /workspace

ENV DOTNET_CLI_TELEMETRY_OPTOUT=1
ENV DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
ENV DOTNET_GENERATE_ASPNET_CERTIFICATE=false
ENV TERM=xterm
