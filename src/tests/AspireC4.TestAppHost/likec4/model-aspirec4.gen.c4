specification {
  element container
  element executable
  relationship RESP
  relationship tcp-ip
  tag local-dev
  tag state-exited
  tag state-running
  tag state-starting
}

model {
  aspirec4 = container 'LikeC4' {
    #state-running
    technology 'likec4/likec4'
    summary 'Describe your system architecture with code. Visualize, validate and share — all from a single source of truth.'
    icon @/likec4/likec4-logo.svg
    link https://likec4.dev/ 'Learn more about LikeC4'
    link https://github.com/likec4/likec4/ 'LikeC4 on GitHub'
    link https://github.com/sponsors/likec4 'Sponsor LikeC4 🩷'
    link https://github.com/davydkov 'Connect with the author on GitHub'
    link http://localhost:56358/view/index 'Endpoint: http'
    link https://localhost:17134/consolelogs/resource/aspirec4 'Dashboard: Console Logs'
    link https://localhost:17134/structuredlogs/resource/aspirec4 'Dashboard: Structured Logs'
    metadata {
      aspire-name 'aspirec4'
    }
  }
  azure_redis = container 'Azure Redis' {
    #state-running
    technology 'Azure Redis'
    summary 'Short term caching, used for cross-instance caching'
    description '''
A **Managed Azure** Redis instance allowing fast access to previously cached data and values.

Used with the **Cache Aside** pattern, where the application can check Redis for cached data before falling back to the primary data store (Postgres in this case).

Cache usage will be non-critical and short-lived, ideal for session caching or caching frequently accessed data that doesn\'t require strong consistency.

Callers must:

- Assume cache is empty
- Populate with a TTL (Time To Live) to prevent stale data
- Ensure keys follow the pattern: `{service}:{key}`

  '''
    icon azure:azure-managed-redis
    link https://learn.microsoft.com/azure/azure-cache-for-redis/cache-overview 'Learn more about Azure Redis'
    link https://azure.com/ 'Learn more about Azure'
    link https://redis.io/ 'Learn more about Redis'
    link https://localhost:17134/consolelogs/resource/azure-redis 'Dashboard: Console Logs'
    link https://localhost:17134/structuredlogs/resource/azure-redis 'Dashboard: Structured Logs'
    metadata {
      aspire-name 'azure-redis'
    }
  }
  azure_postgres = container 'Azure Postgres' {
    #state-running
    technology 'library/postgres'
    summary 'Azure Managed Postgres Flexible Server'
    description '''
An **Azure Managed** Postgres instance for testing
  '''
    icon azure:arc-postgre-sql
    link https://learn.microsoft.com/azure/postgresql/flexible-server/overview 'Learn more about Azure Postgres Flexible Server'
    link https://www.postgresql.org/ 'Learn more about Postgres'
    link https://azure.com/ 'Learn more about Azure'
    link https://localhost:17134/consolelogs/resource/azure-postgres 'Dashboard: Console Logs'
    link https://localhost:17134/structuredlogs/resource/azure-postgres 'Dashboard: Structured Logs'
    metadata {
      Azure_SKU 'Flexible Server x 1 (NON-PROD)'
      Azure_SKU 'Flexible Server x 2 (PROD)'
      Use_Case 'Primary data store'
      aspire-name 'azure-postgres'
    }
  }
  redis = container 'redis' {
    #state-running #local-dev
    technology 'library/redis'
    summary 'Local redis for development'
    description '''
For testing **locally**, uses Redis as a container.

When using Azure Managed Redis with `.RunAsContainer()`, the application will differenciate between that and a real Redis resource using `.AddRedis(...)` and pick the correct icon/ technology.
  '''
    icon tech:redis
    link https://redis.io/ 'Learn more about Redis'
    link https://localhost:17134/consolelogs/resource/redis 'Dashboard: Console Logs'
    link https://localhost:17134/structuredlogs/resource/redis 'Dashboard: Structured Logs'
    metadata {
      aspire-name 'redis'
    }
  }
  postgres = container 'postgres' {
    #state-running #local-dev
    technology 'library/postgres'
    summary 'Local Postgres for development'
    description '''
For testing Azure Postgres vs. local Postgres
  '''
    icon tech:postgresql
    link https://www.postgresql.org/ 'Learn more about Postgres'
    link https://localhost:17134/consolelogs/resource/postgres 'Dashboard: Console Logs'
    link https://localhost:17134/structuredlogs/resource/postgres 'Dashboard: Structured Logs'
    metadata {
      aspire-name 'postgres'
    }
  }
  node_app = executable 'Sample Node App' {
    #state-starting
    description '''
A sample Node.js application that connects to Azure Redis and Azure Postgres
  '''
    icon tech:nodejs
    link http://localhost:56354 'Endpoint: http'
    link https://localhost:17134/consolelogs/resource/node-app 'Dashboard: Console Logs'
    link https://localhost:17134/structuredlogs/resource/node-app 'Dashboard: Structured Logs'
    metadata {
      aspire-name 'node-app'
    }
  }
  node_app_installer = executable 'node-app-installer' {
    #state-exited
    icon tech:nodejs
    link https://localhost:17134/consolelogs/resource/node-app-installer 'Dashboard: Console Logs'
    link https://localhost:17134/structuredlogs/resource/node-app-installer 'Dashboard: Structured Logs'
    metadata {
      aspire-name 'node-app-installer'
    }
  }

  redis .RESP azure_redis 'syncs with' {
    technology 'Redis Protocol'
  }
  postgres .tcp-ip azure_postgres 'syncs with' {
    technology 'PostgreSQL / JDBC'
  }
  node_app .RESP azure_redis 'Caches sessions' {
    technology 'Redis Protocol'
  }
  node_app .RESP redis 'Caches  sessions (local)' {
    technology 'Redis Protocol'
  }
  node_app .tcp-ip azure_postgres 'Persists data' {
    technology 'PostgreSQL / JDBC'
  }
  node_app .tcp-ip postgres 'Persists data (local)' {
    technology 'PostgreSQL / JDBC'
  }
  node_app_installer -> node_app 'Parent'
}

views {
  view index {
    title 'AspireC4 Test App Host'
    group 'Local Dev/ Sync Group' {
      include redis, postgres
    }
    include *
    style element.tag = #state-starting {
      color sky
    }
    style element.tag = #state-running {
      color green
    }
    style element.tag = #state-exited {
      color muted
      opacity 30%
    }
  }
}
