specification {
  element container
  element executable
}

model {
  azure_redis = container 'Redis' {
    technology 'Azure Redis'
    description 'A managed Redis instance for testing'
    icon tech:redis
  }
  azure_postgres = container 'Postgres' {
    technology 'library/postgres'
    description 'A managed Postgres instance for testing'
    icon tech:postgresql
  }
  redis = container 'redis' {
    technology 'library/redis'
    description 'For testing Azure Redis vs. local Redis'
    icon tech:redis
  }
  postgres = container 'postgres' {
    technology 'library/postgres'
    description 'For testing Azure Postgres vs. local Postgres'
    icon tech:postgresql
  }
  node_app = executable 'Node App' {
    technology 'Node.js'
    description 'A sample Node.js application that connects to Azure Redis and Azure Postgres'
    icon tech:nodejs
  }
  node_app_installer = executable 'node-app-installer'

  node_app -> azure_redis 'Caches sessions' {
    technology 'Redis Protocol'
  }
  node_app -> redis 'Caches  sessions (local)' {
    technology 'Redis Protocol'
  }
  node_app -> azure_postgres 'Persists data' {
    technology 'PostgreSQL / JDBC'
  }
  node_app -> postgres 'Persists data (local)' {
    technology 'PostgreSQL / JDBC'
  }
  node_app_installer -> node_app 'Parent'
}

views {
  view index {
    title 'Architecture'
    include *
    style azure_redis, azure_postgres, redis, postgres, node_app {
      color green
    }
    style node_app_installer {
      color muted
      opacity 30%
    }
  }
}
