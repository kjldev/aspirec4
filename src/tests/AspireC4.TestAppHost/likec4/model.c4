specification {
  element container
  element executable
  relationship RESP
  relationship tcp-ip
}

model {
  azure_redis = container 'Redis' {
    technology 'Azure Redis'
    summary 'Azure Managed Redis'
    description '''
A **Managed Azure** Redis instance for testing
'''
    icon azure:azure-managed-redis
  }
  azure_postgres = container 'Postgres' {
    technology 'library/postgres'
    summary 'Azure Managed Postgres Flexible Server'
    description '''
An **Azure Managed** Postgres instance for testing
'''
    icon azure:azure-database-postgre-sql-server
  }
  redis = container 'redis' {
    technology 'library/redis'
    summary 'Local redis for development'
    description '''
For testing **locally**, uses Redis as a container
'''
    icon tech:redis
  }
  postgres = container 'postgres' {
    technology 'library/postgres'
    summary 'Local Postgres for development'
    description '''
For testing Azure Postgres vs. local Postgres
'''
    icon tech:postgresql
  }
  node_app = executable 'Node App' {
    technology 'Node.js'
    description '''
A sample Node.js application that connects to Azure Redis and Azure Postgres
'''
    icon tech:nodejs
  }
  node_app_installer = executable 'node-app-installer' {
    icon tech:nodejs
  }

  redis .RESP azure_redis 'syncs with' {
    technology 'Redis Protocol'
  }
  postgres .tcp-ip azure_postgres 'syncs with' {
    technology 'PostgreSQL / JDBC'
  }
  node_app .RESP azure_redis 'Caches sessions' {
    technology 'Redis Protocol'
  }
  node_app .RESP redis 'Caches  sessions (local)' {
    technology 'Redis Protocol'
  }
  node_app .tcp-ip azure_postgres 'Persists data' {
    technology 'PostgreSQL / JDBC'
  }
  node_app .tcp-ip postgres 'Persists data (local)' {
    technology 'PostgreSQL / JDBC'
  }
  node_app_installer -> node_app 'Parent'
}

views {
  view index {
    title 'Architecture'
    include *
    style azure_redis, azure_postgres, redis, postgres, node_app {
      color green
    }
    style node_app_installer {
      color muted
      opacity 30%
    }
  }
}
