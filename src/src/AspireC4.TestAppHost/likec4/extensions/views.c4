// Custom architecture views.
// These complement the auto-generated index view with additional architectural perspectives.

views {
  view data_stores {
    title 'Data Stores'
    include azure_redis, azure_postgres, local_redis, local_postgres
    include -> azure_redis ->
    include -> azure_postgres ->
  }

  view services {
    title 'Application Services'
    include node_app
    include -> node_app ->
    style element.tag = #local-dev {
      color secondary
    }
  }
}
