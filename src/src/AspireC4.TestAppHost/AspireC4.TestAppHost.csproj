<Project Sdk="Aspire.AppHost.Sdk/13.3.3">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<!-- Emit compiler generated files for debugging purposes -->
		<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Aspire.Hosting.Azure.PostgreSQL" />
		<PackageReference Include="Aspire.Hosting.Azure.Redis" />
		<PackageReference Include="Aspire.Hosting.JavaScript" />
	</ItemGroup>

	<ItemGroup>
		<Content
			Include="..\..\..\assets\images\kjldev-logo.png"
			Link="likec4\images\test-badge.png"
			CopyToOutputDirectory="PreserveNewest"
		/>
		<Content
			Include="..\..\..\assets\images\likec4\likec4-logo.svg"
			Link="likec4\images\test-logo.svg"
			CopyToOutputDirectory="PreserveNewest"
		/>

		<Content
			Include="likec4\extensions\*.c4"
			Link="likec4-extensions\%(Filename)%(Extension)"
			CopyToOutputDirectory="PreserveNewest"
		/>
		<Content Include="likec4\images\*" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\AspireC4\AspireC4.csproj" IsAspireProjectResource="false" />
		<ProjectReference
			Include="..\AspireC4.SourceGenerators\AspireC4.SourceGenerators.csproj"
			OutputItemType="Analyzer"
			ReferenceOutputAssembly="false"
			IsAspireProjectResource="false"
		/>
	</ItemGroup>
</Project>
